            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="n32" value="32" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#FFFFFF;strokeWidth=2;" parent="e32" vertex="1" connectable="0">
