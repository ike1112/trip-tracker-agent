            <mxPoint x="-11" y="-11" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="g1-badge" value="1-3" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#2674C2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#2674C2;" parent="1" vertex="1">
          <mxGeometry x="1780" y="50" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g1-text" value="&lt;b&gt;Open chat&lt;/b&gt; — You open the local &lt;b&gt;Web UI&lt;/b&gt; (FastAPI + Gradio), log in via &lt;b&gt;Cognito&lt;/b&gt; (OAuth2 code), and the UI calls the &lt;b&gt;Agent API Gateway&lt;/b&gt; with the user JWT." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="46" width="340" height="64" as="geometry" />
        </mxCell>
        <mxCell id="g2-badge" value="4-5" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#2674C2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#2674C2;" parent="1" vertex="1">
          <mxGeometry x="1780" y="120" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g2-text" value="&lt;b&gt;Authorize&lt;/b&gt; — API Gateway invokes the &lt;b&gt;Agent Authorizer Lambda&lt;/b&gt;, which verifies the JWT against Cognito JWKS (RS256). The Travel Agent re-verifies in-handler — defense in depth (ADR 0006)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="116" width="340" height="76" as="geometry" />
        </mxCell>
        <mxCell id="g3-badge" value="6-7" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#2674C2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#2674C2;" parent="1" vertex="1">
          <mxGeometry x="1780" y="202" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g3-text" value="&lt;b&gt;Reason&lt;/b&gt; — API Gateway invokes &lt;b&gt;Travel Agent&lt;/b&gt; (Strands). Reasoning runs on &lt;b&gt;Bedrock Claude Sonnet 4.5&lt;/b&gt;." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="198" width="340" height="52" as="geometry" />
        </mxCell>
        <mxCell id="g4-badge" value="8-9" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#2674C2;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#2674C2;" parent="1" vertex="1">
          <mxGeometry x="1780" y="260" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g4-text" value="&lt;b&gt;Persist&lt;/b&gt; — Session memory persists in &lt;b&gt;S3&lt;/b&gt;. Local watch-CRUD tools hit &lt;b&gt;DynamoDB Watches&lt;/b&gt;; user_id is bound by a closure factory (ADR 0001), so the LLM never supplies it." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="256" width="340" height="78" as="geometry" />
        </mxCell>
        <mxCell id="g5-badge" value="10-12" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#ED7100;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#ED7100;" parent="1" vertex="1">
          <mxGeometry x="1780" y="346" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g5-text" value="&lt;b&gt;Live prices: mint JWT&lt;/b&gt; — Agent reads its signing secret from &lt;b&gt;Secrets Manager&lt;/b&gt;, mints a per-component JWT (ADR 0006), and calls the &lt;b&gt;flights MCP&lt;/b&gt; and &lt;b&gt;hotels MCP&lt;/b&gt; API Gateways." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="342" width="335" height="80" as="geometry" />
        </mxCell>
        <mxCell id="g6-badge" value="13-17" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#ED7100;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#ED7100;" parent="1" vertex="1">
          <mxGeometry x="1780" y="434" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g6-text" value="&lt;b&gt;Verify &amp;amp; route&lt;/b&gt; — Each MCP Authorizer verifies HS256 against the &lt;b&gt;agent OR poller&lt;/b&gt; signing secret (per-component isolation), then routes to the MCP server Lambda. Handler re-verifies." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="430" width="335" height="80" as="geometry" />
        </mxCell>
        <mxCell id="g7-badge" value="18-19" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#ED7100;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#ED7100;" parent="1" vertex="1">
          <mxGeometry x="1780" y="522" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g7-text" value="&lt;b&gt;External APIs&lt;/b&gt; — &lt;b&gt;flights-mcp&lt;/b&gt; calls &lt;b&gt;Duffel&lt;/b&gt;; &lt;b&gt;hotels-mcp&lt;/b&gt; calls &lt;b&gt;LiteAPI&lt;/b&gt;. In fixture mode (ADR 0002) recorded JSON is replayed instead — no provider key needed." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="518" width="335" height="68" as="geometry" />
        </mxCell>
        <mxCell id="g8-badge" value="20-22" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#9673A6;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#9673A6;" parent="1" vertex="1">
          <mxGeometry x="1780" y="598" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g8-text" value="&lt;b&gt;Schedule&lt;/b&gt; — &lt;b&gt;EventBridge&lt;/b&gt; fires the &lt;b&gt;Poller&lt;/b&gt; every 4h. Poller reads its OWN signing secret (different from the agent&#39;s; ADR 0006) and queries &lt;b&gt;DynamoDB Watches&lt;/b&gt; via the status-index GSI (ADR 0007) for active watches." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="594" width="335" height="106" as="geometry" />
        </mxCell>
        <mxCell id="g9-badge" value="23-26" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#9673A6;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#9673A6;" parent="1" vertex="1">
          <mxGeometry x="1780" y="712" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g9-text" value="&lt;b&gt;Snapshot &amp;amp; decide&lt;/b&gt; — Poller calls flights+hotels MCP with sub=trip-tracker-poller, writes a &lt;b&gt;FareHistory&lt;/b&gt; snapshot (90-day TTL), pulls the 30-day window, runs dedup / threshold / anomaly gates. If a gate fires, &lt;b&gt;Bedrock Haiku 4.5&lt;/b&gt; decides alert-worthiness with a one-line reason (ADR 0004; stubbable)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="708" width="335" height="124" as="geometry" />
        </mxCell>
        <mxCell id="g10-badge" value="27-30" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1780" y="844" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g10-text" value="&lt;b&gt;Notify &amp;amp; writeback&lt;/b&gt; — Poller async-invokes &lt;b&gt;Notifier&lt;/b&gt;, which sends the trip-alert via &lt;b&gt;SES&lt;/b&gt; to your inbox, then writes lastAlertedAt + lastAlertedPrice back to Watches (idempotent, ADR 0005)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1835" y="840" width="335" height="74" as="geometry" />
        </mxCell>
        <mxCell id="g11-badge" value="31" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#7AA116;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#7AA116;" parent="1" vertex="1">
          <mxGeometry x="1780" y="926" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g11-text" value="&lt;b&gt;Cost ceiling&lt;/b&gt; — &lt;b&gt;AWS Budgets&lt;/b&gt; at $10/month sends a direct email to your inbox — hard backstop against a runaway loop." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="922" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="g12-badge" value="32" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1780" y="982" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g12-text" value="&lt;b&gt;You receive the alert&lt;/b&gt; — Both the trip-alert email and any cost-alarm email arrive in &lt;b&gt;Your inbox&lt;/b&gt; — closing the loop that started when you described the trip in chat." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1830" y="978" width="340" height="56" as="geometry" />
        </mxCell>
