        <mxCell id="m16" value="16" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
