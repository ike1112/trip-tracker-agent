        <mxCell id="m17" value="17" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="1378" y="250" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m18" value="18" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="700" y="867" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6878;strokeWidth=1;dashed=0;" parent="1" vertex="1">
          <mxGeometry x="220" y="690" width="1170" height="100" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Legend" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="240" y="700" width="100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="legend-c-title" value="Arrow color  =  which phase the action belongs to" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#5A6878;" parent="1" vertex="1">
          <mxGeometry x="240" y="724" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-s1" value="" style="rounded=0;fillColor=#2674C2;strokeColor=#2674C2;" parent="1" vertex="1">
          <mxGeometry x="240" y="754" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="legend-s1l" value="Upload" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="265" y="751" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-s2" value="" style="rounded=0;fillColor=#ED7100;strokeColor=#ED7100;" parent="1" vertex="1">
          <mxGeometry x="360" y="754" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="legend-s2l" value="Process" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="385" y="751" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-s3" value="" style="rounded=0;fillColor=#E7157B;strokeColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="480" y="754" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="legend-s3l" value="Push" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="505" y="751" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-l-title" value="Line style  =  call type" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#5A6878;" parent="1" vertex="1">
          <mxGeometry x="700" y="724" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-solid" style="endArrow=classic;html=1;strokeColor=#232F3E;strokeWidth=2;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="761" as="sourcePoint" />
            <mxPoint x="760" y="761" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend-solidl" value="solid = synchronous call" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="770" y="751" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-dashed" style="endArrow=classic;html=1;strokeColor=#232F3E;strokeWidth=2;dashed=1;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="761" as="sourcePoint" />
            <mxPoint x="1030" y="761" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend-dashedl" value="dashed = async / out-of-band" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1040" y="751" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-num" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="700" y="775" width="18" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend-numl" value="numbered circles mark each arrow — see grouped descriptions on the right →" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;fontStyle=2;" parent="1" vertex="1">
          <mxGeometry x="725" y="772" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="g1-badge" value="1-2" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="96" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g1-text" value="&lt;b&gt;Request URL&lt;/b&gt; — Mobile calls &lt;b&gt;POST /upload-url&lt;/b&gt;. API Gateway authenticates the request and routes it to &lt;b&gt;Upload Lambda&lt;/b&gt;." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1660" y="92" width="330" height="56" as="geometry" />
        </mxCell>
        <mxCell id="g2-badge" value="3-4" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="160" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g2-text" value="&lt;b&gt;Register &amp;amp; reserve&lt;/b&gt; — Upload Lambda writes a &lt;b&gt;Datasets&lt;/b&gt; row (status=PENDING_UPLOAD) and registers the device&#39;s push token in &lt;b&gt;DeviceTokens,&lt;/b&gt;&amp;nbsp;then returns { presignedUrl, datasetId }." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1660" y="156" width="330" height="86" as="geometry" />
        </mxCell>
        <mxCell id="g3-badge" value="5" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="254" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g3-text" value="&lt;b&gt;Upload file&lt;/b&gt; — Mobile &lt;b&gt;PUTs&lt;/b&gt; the file directly to &lt;b&gt;Amazon S3&lt;/b&gt;&amp;nbsp;using the presigned URL." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1660" y="250" width="330" height="64" as="geometry" />
        </mxCell>
        <mxCell id="g4-badge" value="6-8" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="328" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g4-text" value="&lt;b&gt;Trigger processing&lt;/b&gt; — S3 emits an &lt;b&gt;ObjectCreated&lt;/b&gt; event to &lt;b&gt;UploadComplete Lambda&lt;/b&gt;, which marks Datasets as UPLOADED, saves other metadata, and creates a &lt;b&gt;ProcessingJobs&lt;/b&gt; row &lt;b&gt;&lt;i&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;(if autoprocess=true).&lt;/font&gt;&lt;/i&gt;&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1660" y="324" width="330" height="84" as="geometry" />
        </mxCell>
        <mxCell id="g5-badge" value="9-11" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="420" width="40" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g5-text" value="&lt;b&gt;Run workflow&lt;/b&gt; — UploadComplete calls &lt;b&gt;StartExecution&lt;/b&gt;. &lt;b&gt;Step Functions&lt;/b&gt; launches an &lt;b&gt;ECS Fargate&lt;/b&gt; task. Fargate reads from S3 uploads/ and writes to S3 outputs." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1660" y="416" width="330" height="96" as="geometry" />
        </mxCell>
        <mxCell id="g6-badge" value="12-13" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="524" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g6-text" value="&lt;b&gt;Mark done &amp;amp; invoke&lt;/b&gt; — Step Functions updates ProcessingJobs to &lt;b&gt;status=SUCCESS/FAILED&lt;/b&gt;. If &lt;b&gt;&lt;i&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;autopush=true&lt;/font&gt;&lt;/i&gt;&lt;/b&gt;, it invokes &lt;b&gt;Notify Lambda&lt;/b&gt;." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1665" y="520" width="325" height="74" as="geometry" />
        </mxCell>
        <mxCell id="g7-badge" value="14-16" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="606" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g7-text" value="&lt;b&gt;Publish push&lt;/b&gt; — &lt;b&gt;Notify Lambda&lt;/b&gt; reads the device endpoint ARN from DeviceTokens, records the attempt on ProcessingJobs.pushStatus, and &lt;b&gt;Publishes&lt;/b&gt; to &lt;b&gt;SNS Mobile Push&lt;/b&gt;.&lt;br&gt;Preferred payload: { datasetId, jobId, presignedDownloadUrl }.&lt;br&gt;Fallback payload: { datasetId, jobId } when the URL will not fit the push." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1665" y="602" width="325" height="108" as="geometry" />
        </mxCell>
        <mxCell id="g8-badge" value="17-18" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#FFFFFF;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;strokeColor=#232F3E;" parent="1" vertex="1">
          <mxGeometry x="1610" y="724" width="46" height="22" as="geometry" />
        </mxCell>
        <mxCell id="g8-text" value="&lt;b&gt;Deliver to device&lt;/b&gt; — SNS Mobile Push delivers the notification via Apple &lt;b&gt;APNs&lt;/b&gt; (iOS) or Google &lt;b&gt;FCM&lt;/b&gt; (Android). The device opens &lt;b&gt;presignedDownloadUrl&lt;/b&gt; directly when it is present and still valid; otherwise — fallback payload or an expired URL — it calls the &lt;b&gt;Status API&lt;/b&gt; for a fresh URL." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#232F3E;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1665" y="720" width="325" height="86" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
