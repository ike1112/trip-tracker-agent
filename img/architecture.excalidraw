    {"type":"rectangle","id":"agentfn","x":715,"y":135,"width":220,"height":260,"backgroundColor":"#ffc9c9","fillStyle":"solid","strokeColor":"#b91c1c","strokeWidth":2,"roundness":{"type":3},"label":{"text":"Travel Agent Lambda\n(Python 3.13, ARM64)\n1024 MB / 30s\n\nStrands Agents SDK\nS3SessionManager\n\nIn-process tools:\n  get_user_location\n  get_todays_date\n\nMints HS256 JWT\nper user → MCP","fontSize":13}},

    {"type":"rectangle","id":"mcpfn","x":715,"y":420,"width":220,"height":255,"backgroundColor":"#ffc9c9","fillStyle":"solid","strokeColor":"#b91c1c","strokeWidth":2,"roundness":{"type":3},"label":{"text":"Bookings MCP Lambda\n(Node 22, ARM64)\n1024 MB / 10s\n\nLambda Web Adapter\n+ Express + MCP TS SDK\n\nTools:\n  get-travel-policies\n  get-available-cars\n  book-car / book-hotel\n\nStateless per request","fontSize":13}},

    {"type":"rectangle","id":"layers","x":715,"y":700,"width":220,"height":135,"backgroundColor":"#fff3bf","fillStyle":"solid","strokeColor":"#a16207","strokeWidth":2,"roundness":{"type":3},"label":{"text":"Lambda Layers\n\nLWA (ARM64 v25)\nfor MCP Express app\n\nPython deps layer\n(strands, mcp, jwt)","fontSize":13}},

    {"type":"rectangle","id":"s3","x":975,"y":135,"width":190,"height":140,"backgroundColor":"#b2f2bb","fillStyle":"solid","strokeColor":"#15803d","strokeWidth":2,"roundness":{"type":3},"label":{"text":"S3 Bucket\nAgent Sessions\n\nKey:\nagent_sessions/\nsession_for_user_{sub}","fontSize":13}},
    {"type":"text","id":"s3-note","x":980,"y":280,"width":180,"height":16,"text":"One key per Cognito sub","fontSize":12,"strokeColor":"#6b6b6b"},
    {"type":"text","id":"s3-note2","x":980,"y":296,"width":180,"height":16,"text":"= per-user state isolation","fontSize":12,"strokeColor":"#6b6b6b"},

