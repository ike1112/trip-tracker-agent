    {"type":"text","id":"why-title","x":1210,"y":110,"width":380,"height":24,"text":"DESIGN — Why this shape?","fontSize":17,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"why1","x":1200,"y":140,"width":380,"height":140,"backgroundColor":"#fff3bf","fillStyle":"solid","strokeColor":"#a16207","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"why1-h","x":1212,"y":150,"width":380,"height":20,"text":"1. Two-tier JWT (zero identity-by-LLM)","fontSize":15,"strokeColor":"#a16207"},
    {"type":"text","id":"why1-a","x":1212,"y":175,"width":380,"height":18,"text":"User -> Agent: Cognito RS256 (real user)","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why1-b","x":1212,"y":195,"width":380,"height":18,"text":"Agent -> MCP : HS256, sub=travel-agent,","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why1-c","x":1212,"y":215,"width":380,"height":18,"text":"                                user_id propagated as claim","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why1-d","x":1212,"y":240,"width":380,"height":18,"text":"User identity is NEVER inferred from","fontSize":13,"strokeColor":"#b91c1c"},
    {"type":"text","id":"why1-e","x":1212,"y":258,"width":380,"height":18,"text":"the LLM response - always from a JWT.","fontSize":13,"strokeColor":"#b91c1c"},

    {"type":"rectangle","id":"why2","x":1200,"y":300,"width":380,"height":135,"backgroundColor":"#d3f9d8","fillStyle":"solid","strokeColor":"#15803d","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"why2-h","x":1212,"y":310,"width":380,"height":20,"text":"2. Stateless compute, externalised state","fontSize":15,"strokeColor":"#15803d"},
    {"type":"text","id":"why2-a","x":1212,"y":335,"width":380,"height":18,"text":"Agent + MCP Lambdas hold no state.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why2-b","x":1212,"y":355,"width":380,"height":18,"text":"S3SessionManager keys conversation by","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why2-c","x":1212,"y":375,"width":380,"height":18,"text":"Cognito sub - safe across cold starts","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why2-d","x":1212,"y":395,"width":380,"height":18,"text":"and concurrent Lambda instances.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why2-e","x":1212,"y":415,"width":380,"height":18,"text":"MCP transport: sessionIdGenerator=undefined.","fontSize":13,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"why3","x":1200,"y":455,"width":380,"height":130,"backgroundColor":"#e5dbff","fillStyle":"solid","strokeColor":"#6d28d9","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"why3-h","x":1212,"y":465,"width":380,"height":20,"text":"3. User-aware tools end-to-end","fontSize":15,"strokeColor":"#6d28d9"},
    {"type":"text","id":"why3-a","x":1212,"y":490,"width":380,"height":18,"text":"MCP Authorizer pulls user_id/user_name","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why3-b","x":1212,"y":510,"width":380,"height":18,"text":"out of HS256 JWT and attaches them to","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why3-c","x":1212,"y":530,"width":380,"height":18,"text":"req.auth -> ctx.authInfo in every tool.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why3-d","x":1212,"y":555,"width":380,"height":18,"text":"Tools cite user by name in responses,","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why3-e","x":1212,"y":573,"width":380,"height":18,"text":"never trusting prompt-supplied identity.","fontSize":13,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"why4","x":1200,"y":605,"width":380,"height":135,"backgroundColor":"#ffd8a8","fillStyle":"solid","strokeColor":"#9a3412","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"why4-h","x":1212,"y":615,"width":380,"height":20,"text":"4. Lambda Web Adapter for MCP server","fontSize":15,"strokeColor":"#9a3412"},
    {"type":"text","id":"why4-a","x":1212,"y":640,"width":380,"height":18,"text":"Lets us run an unmodified Express +","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why4-b","x":1212,"y":660,"width":380,"height":18,"text":"MCP TS SDK app on Lambda. AWS_LWA_PORT","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why4-c","x":1212,"y":680,"width":380,"height":18,"text":"=3001, /opt/bootstrap = exec wrapper.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why4-d","x":1212,"y":705,"width":380,"height":18,"text":"Same code can run locally as a regular","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why4-e","x":1212,"y":723,"width":380,"height":18,"text":"streamable-HTTP MCP server.","fontSize":13,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"why5","x":1200,"y":760,"width":380,"height":110,"backgroundColor":"#a5d8ff","fillStyle":"solid","strokeColor":"#2563eb","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"why5-h","x":1212,"y":770,"width":380,"height":20,"text":"5. Cost / latency choices","fontSize":15,"strokeColor":"#2563eb"},
    {"type":"text","id":"why5-a","x":1212,"y":795,"width":380,"height":18,"text":"ARM64 Graviton on every Lambda.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why5-b","x":1212,"y":815,"width":380,"height":18,"text":"Claude 3.5 Haiku - cheap, fast model.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why5-c","x":1212,"y":835,"width":380,"height":18,"text":"Regional REST API GW (no edge cache).","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"why5-d","x":1212,"y":853,"width":380,"height":18,"text":"Token authorizers, no IAM signing on UI.","fontSize":13,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"prod-warn","x":1200,"y":890,"width":380,"height":80,"backgroundColor":"#ffc9c9","fillStyle":"solid","strokeColor":"#b91c1c","strokeWidth":2,"roundness":{"type":3}},
    {"type":"text","id":"pw-h","x":1212,"y":900,"width":380,"height":18,"text":"PROD HARDENING (gaps in this sample)","fontSize":14,"strokeColor":"#b91c1c"},
    {"type":"text","id":"pw-a","x":1212,"y":920,"width":380,"height":16,"text":"- Move JWT_SIGNATURE_SECRET to Secrets","fontSize":12,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"pw-b","x":1212,"y":937,"width":380,"height":16,"text":"   Manager (currently env var, hardcoded).","fontSize":12,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"pw-c","x":1212,"y":953,"width":380,"height":16,"text":"- Scope bedrock:InvokeModel to a model ARN.","fontSize":12,"strokeColor":"#1e1e1e"},

    {"type":"text","id":"flow-title","x":40,"y":900,"width":400,"height":22,"text":"USER FLOW (numbered on diagram)","fontSize":16,"strokeColor":"#1e1e1e"},

    {"type":"rectangle","id":"flowbox","x":30,"y":925,"width":1140,"height":210,"backgroundColor":"#fff3bf","fillStyle":"solid","strokeColor":"#a16207","strokeWidth":1,"opacity":50,"roundness":{"type":3}},

    {"type":"text","id":"step1","x":45,"y":938,"width":1100,"height":18,"text":"1  User opens http://localhost:8000/chat in browser.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step2","x":45,"y":957,"width":1100,"height":18,"text":"2  Web UI has no session -> redirects to Cognito Hosted UI (OAuth authorization-code flow, scope: openid email profile).","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step3","x":45,"y":976,"width":1100,"height":18,"text":"3  User logs in (Alice/Bob, Passw0rd@). Cognito redirects back to /callback with code; oauth.py exchanges it for access_token + id_token (8h TTL) and stores them in the FastAPI session.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step4","x":45,"y":995,"width":1100,"height":18,"text":"4  User types a prompt. Web UI sends POST { text } to Agent API GW with Authorization: Bearer <Cognito JWT>.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step5","x":45,"y":1014,"width":1100,"height":18,"text":"5  API GW invokes Agent Authorizer Lambda. It verifies the RS256 signature using public keys from the Cognito JWKS endpoint and returns an Allow/Deny IAM policy.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step6","x":45,"y":1033,"width":1100,"height":18,"text":"6  On Allow, API GW invokes Travel Agent Lambda. It re-decodes the JWT to extract sub + username, builds a composite prompt with sourceIp from API GW request context.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step7","x":45,"y":1052,"width":1100,"height":18,"text":"7  Strands Agent is constructed per request. S3SessionManager(session_id=session_for_user_{sub}) loads prior turns from S3 (read).","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step8","x":45,"y":1071,"width":1100,"height":18,"text":"8  mcp_client_manager mints an HS256 JWT signed with JWT_SIGNATURE_SECRET (sub=travel-agent, user_id=<sub>, user_name=<username>) and connects an MCP streamable-HTTP client to the MCP API.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step9","x":45,"y":1090,"width":1100,"height":18,"text":"9  MCP Authorizer accepts only sub=travel-agent. MCP Lambda re-verifies the same JWT in middleware and copies claims to req.auth -> tools see ctx.authInfo.user_name.","fontSize":13,"strokeColor":"#1e1e1e"},
    {"type":"text","id":"step10","x":45,"y":1109,"width":1100,"height":18,"text":"10 Agent loops: Bedrock (Claude 3.5 Haiku, us-east-1) reasons -> calls in-process tools (location, date) and MCP tools (policies, cars, book-*) -> answers; final turn is persisted back to S3; text returned to Web UI -> rendered to user.","fontSize":13,"strokeColor":"#1e1e1e"}
  ]
}
