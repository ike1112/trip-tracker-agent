    {"type":"arrow","id":"f5","x":575,"y":230,"width":0,"height":30,"points":[[0,0],[0,30]],"strokeColor":"#9a3412","strokeWidth":2,"endArrowhead":"arrow","label":{"text":"5  authorize","fontSize":13},"startBinding":{"elementId":"agentapi","fixedPoint":[0.5,1]},"endBinding":{"elementId":"agentauth","fixedPoint":[0.5,0]}},

    {"type":"arrow","id":"f6","x":475,"y":340,"width":-40,"height":130,"points":[[0,0],[-40,130]],"strokeColor":"#a21caf","strokeWidth":2,"endArrowhead":"arrow","strokeStyle":"dashed","label":{"text":"6  fetch JWKS","fontSize":13},"startBinding":{"elementId":"agentauth","fixedPoint":[0,0.7]},"endBinding":{"elementId":"jwks","fixedPoint":[1,0.3]}},

