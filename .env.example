# trip-tracker — deploy configuration template
#
# This project takes no runtime .env file: every value below is a CDK
# *context* key. CDK injects it into the relevant Lambda's environment at
# `cdk deploy`. Supply values one of two ways:
#
#   1. Per deploy:   cdk deploy -c duffelApiKey=$DUFFEL_API_KEY -c sesMode=live ...
#   2. Persisted:    add them under "context" in cdk.json (do NOT commit secrets)
#
# Copy this file to .env (gitignored) to keep your real values handy, then
# expand them onto the `cdk deploy -c ...` line. Fixture/stub modes need no
# external keys, so the whole external-API block is optional for a dry run.

# ── External travel APIs ─────────────────────────────────────────────────
# Required only when the matching MCP server runs in live mode (mcpMode=live).
# In fixture mode (default) the servers replay recorded responses — leave blank.
duffelApiKey=
liteApiKey=

# ── MCP server mode ──────────────────────────────────────────────────────
# fixture = replay recorded API responses (no keys, no cost, deterministic).
# live    = call Duffel/LiteAPI for real (requires the keys above).
mcpMode=fixture

# ── Bedrock (alert-worthiness decision) ──────────────────────────────────
# bedrockMode: stub = no Bedrock call (tests/dry runs); live = real inference.
bedrockMode=stub
# Model id for the poller's decision call (ADR 0004). Needs Bedrock access
# to this model in the deploy region.
bedrockModelId=claude-haiku-4-5-20251001
# Model id for the chat agent. Optional; defaults to the agent's own config.
agentBedrockModelId=
# Optional cross-region inference-profile ARN if you front Bedrock with one.
bedrockInferenceProfileArn=

# ── Email alerts (SES) ───────────────────────────────────────────────────
# sesMode: stub = no email sent (tests); live = real SES send.
sesMode=stub
# The verified SES sender identity and the recipient of trip alerts.
# Both are synth-time validated as email addresses when set.
notifierSenderEmail=
notifierRecipientEmail=
# AWS Budget alarm recipient. Falls back to notifierRecipientEmail if unset.
budgetAlarmEmail=

# ── Tuning (optional) ────────────────────────────────────────────────────
# How often the poller runs, in minutes.
pollIntervalMinutes=
# Per-Lambda timeout override, in seconds.
lambdaTimeoutSeconds=
